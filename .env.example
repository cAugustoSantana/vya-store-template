# Neon Postgres connection string (dev branch for local; never use prod locally)
DATABASE_URL=

# Admin panel login password (plain text; compared server-side only at /api/admin/auth)
ADMIN_PASSWORD=

# JWT signing secret for admin sessions (random 32+ chars; keep secret)
ADMIN_SECRET=

# Resend API key — see docs/resend.md
RESEND_API_KEY=

# Vercel Blob read/write token for payment proof uploads — see docs/blob.md
BLOB_READ_WRITE_TOKEN=

# Upstash Redis (optional locally; recommended in production) — see docs/upstash.md
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Set to 1 in CI/E2E to use shorter rate-limit windows
RATE_LIMIT_TEST=
