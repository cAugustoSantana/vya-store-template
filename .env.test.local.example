# Copy to `.env.test.local` for Playwright E2E (never use production DATABASE_URL)
DATABASE_URL=

ADMIN_PASSWORD=e2e-admin-password
ADMIN_SECRET=e2e-test-secret-at-least-32-characters-long

# Dummy key is fine — emails are skipped or fail silently in E2E
RESEND_API_KEY=re_test_dummy

# Required for proof upload E2E tests
BLOB_READ_WRITE_TOKEN=

RATE_LIMIT_TEST=1

# Set to 1 for full-stack E2E (checkout, payment, admin, API). CI should set this.
E2E_STACK=1
